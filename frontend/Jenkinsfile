pipeline {
  agent {
    kubernetes {
      label "node-kaniko-${UUID.randomUUID().toString()}"
      namespace "jdh"
      defaultContainer 'node'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  annotations:
    sidecar.istio.io/inject: "false"
spec:
  restartPolicy: Never
  containers:
    - name: node
      image: node:22.17.1-bullseye
      command: ['cat']
      tty: true
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
    - name: kubectl
      image: bitnami/kubectl:latest
      command: ['sleep', 'infinity']
      tty: true
      securityContext:
        runAsUser: 0
  volumes:
    - name: workspace
      emptyDir: {}
    - name: docker-config
      secret:
        secretName: dockerhub-cred1
        items:
          - key: .dockerconfigjson
            path: config.json
"""
    }
  }

  environment {
    IMAGE_NAME     = 'deatytim/tmfront'
    IMAGE_TAG      = "${env.BUILD_NUMBER}"
    NAMESPACE      = 'jdh'
    SVC_NAME       = 'frontend-service'
    CONTAINER_NAME = 'frontend'
  }

  stages {
    stage('Checkout') {
      steps {
        container('node') {
          checkout scm
        }
      }
    }


    stage('Setup K8s Resources') {
      steps {
        container('kubectl') {
          sh '''
            # DeploymentьЩА IngressыКФ эХньГБ apply (ьЭ┤ып╕ьзА/ьКдэОЩ ыПЩъ╕░эЩФ, slot selectorьЧР ьШБэЦе ьЧЖьЭМ)
            kubectl apply -f - <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-blue-deployment
  namespace: jdh
  labels:
    type: frontend
    slot: blue
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
      slot: blue
  template:
    metadata:
      labels:
        type: frontend
        slot: blue
    spec:
      containers:
        - name: frontend
          image: deatytim/tmfront:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 80
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-green-deployment
  namespace: jdh
  labels:
    type: frontend
    slot: green
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
      slot: green
  template:
    metadata:
      labels:
        type: frontend
        slot: green
    spec:
      containers:
        - name: frontend
          image: deatytim/tmfront:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend-ingress
  namespace: jdh
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/use-regex: "true"
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - www.tallemalletest.kro.kr
      secretName: tallemalle-tls
  rules:
    - host: www.tallemalletest.kro.kr
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend-service
                port:
                  number: 80
EOF

            # ServiceыКФ ьЭ┤ып╕ ьб┤ьЮмэХШый┤ slot selectorые╝ ьЬаьзАэХШъ│а, ьЧЖьЭД ыХМызМ ьГЭьД▒
            if kubectl get svc frontend-service -n jdh > /dev/null 2>&1; then
              echo "frontend-service ьЭ┤ып╕ ьб┤ьЮм тАФ slot selector ьЬаьзА"
            else
              echo "frontend-service ьЧЖьЭМ тАФ slot: blue ыбЬ ь┤Иъ╕░ ьГЭьД▒"
              kubectl apply -f - <<EOF
apiVersion: v1
kind: Service
metadata:
  name: frontend-service
  namespace: jdh
spec:
  selector:
    type: frontend
    slot: blue
  ports:
    - port: 80
      targetPort: 80
EOF
            fi
          '''
        }
      }
    }

    stage('npm Install & Build') {
      steps {
        container('node') {
          dir('frontend') {
            sh '''
              npm install
              npm run build
            '''
          }
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \\
              --context=${WORKSPACE}/frontend \\
              --dockerfile=${WORKSPACE}/frontend/Dockerfile \\
              --destination=${IMAGE_NAME}:${IMAGE_TAG} \\
              --destination=${IMAGE_NAME}:latest \\
              --single-snapshot \\
              --use-new-run \\
              --cache=true \\
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Blue/Green Deploy') {
      steps {
        container('kubectl') {
          script {
            // эШДьЮм ьДЬы╣ДьКдъ░А ъ░АыжмэВдыКФ slot эЩХьЭ╕
            def activeSlot = sh(
              script: "kubectl get svc ${SVC_NAME} -n ${NAMESPACE} -o jsonpath='{.spec.selector.slot}'",
              returnStdout: true
            ).trim()

            // activeъ░А blueый┤ greenьЧР ы░░эПм, greenьЭ┤ый┤ blueьЧР ы░░эПм
            def newSlot   = (activeSlot == 'blue') ? 'green' : 'blue'
            def newDeploy = "frontend-${newSlot}-deployment"

            echo "эШДьЮм active slot: ${activeSlot} тЖТ ы░░эПм ыМАьГБ: ${newSlot}"

            // inactive deploymentьЧР ьГИ ьЭ┤ып╕ьзА ы░░эПм ы░П ыбдьХДьЫГ ыМАъ╕░
            sh """
              kubectl set image deployment/${newDeploy} \\
                ${CONTAINER_NAME}=${IMAGE_NAME}:${IMAGE_TAG} \\
                -n ${NAMESPACE}

              kubectl rollout status deployment/${newDeploy} \\
                -n ${NAMESPACE} --timeout=180s
            """

            // ыбдьХДьЫГ ьД▒ъ│╡ тЖТ ьДЬы╣ДьКд эК╕ыЮШэФ╜ьЭД ьГИ slotьЬ╝ыбЬ ьаДэЩШ
            sh """
              kubectl patch svc ${SVC_NAME} -n ${NAMESPACE} \\
                -p '{"spec":{"selector":{"type":"frontend","slot":"${newSlot}"}}}'
            """

            echo "Blue/Green ьаДэЩШ ьЩДыгМ: ${activeSlot} тЖТ ${newSlot}"
          }
        }
      }
    }
  }

  post {
    success {
      echo "Frontend ы░░эПм ьЩДыгМ: ${IMAGE_NAME}:${IMAGE_TAG}"
    }
    failure {
      echo "Frontend ы░░эПм ьЛдэМи тАФ ьДЬы╣ДьКдыКФ ъ╕░ьб┤ slot ьЬаьзА"
    }
  }
}
