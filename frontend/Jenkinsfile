pipeline {
  agent {
    kubernetes {
      label "node-kaniko-${UUID.randomUUID().toString()}"
      namespace "jdh"
      defaultContainer 'node'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  annotations:
    sidecar.istio.io/inject: "false"
spec:
  restartPolicy: Never
  containers:
    - name: node
      image: node:22.17.1-bullseye
      command: ['cat']
      tty: true
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
    - name: kubectl
      image: bitnami/kubectl:latest
      command: ['sleep', 'infinity']
      tty: true
      securityContext:
        runAsUser: 0
  volumes:
    - name: workspace
      emptyDir: {}
    - name: docker-config
      secret:
        secretName: dockerhub-cred1
        items:
          - key: .dockerconfigjson
            path: config.json
"""
    }
  }

  environment {
    IMAGE_NAME     = 'deatytim/tmfront'
    IMAGE_TAG      = "${env.BUILD_NUMBER}"
    NAMESPACE      = 'jdh'
    SVC_NAME       = 'frontend-service'
    CONTAINER_NAME = 'frontend'
  }

  stages {
    stage('Checkout') {
      steps {
        container('node') {
          checkout scm
        }
      }
    }



    stage('Check Changes') {
      steps {
        script {
          def changedFiles = currentBuild.changeSets.collectMany { cs ->
            cs.items.collectMany { item ->
              item.affectedFiles.collect { it.path }
            }
          }
          echo "변경된 파일:\n${changedFiles.join('\n')}"
          if (!changedFiles.any { it.startsWith('frontend/') }) {
            currentBuild.result = 'ABORTED'
            error('frontend/ 변경 없음 — 빌드 스킵')
          }
        }
      }
    }

    stage('Setup K8s Resources') {
      steps {
        container('kubectl') {
          sh '''
            # Deployment와 Ingress는 항상 apply (이미지/스펙 동기화, slot selector에 영향 없음)
            kubectl apply -f - <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-blue-deployment
  namespace: jdh
  labels:
    type: frontend
    slot: blue
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
      slot: blue
  template:
    metadata:
      labels:
        type: frontend
        slot: blue
    spec:
      containers:
        - name: frontend
          image: deatytim/tmfront:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 80
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-green-deployment
  namespace: jdh
  labels:
    type: frontend
    slot: green
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
      slot: green
  template:
    metadata:
      labels:
        type: frontend
        slot: green
    spec:
      containers:
        - name: frontend
          image: deatytim/tmfront:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend-ingress
  namespace: jdh
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/use-regex: "true"
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - www.tallemalletest.kro.kr
      secretName: tallemalle-tls
  rules:
    - host: www.tallemalletest.kro.kr
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend-service
                port:
                  number: 80
EOF

            # Service는 이미 존재하면 slot selector를 유지하고, 없을 때만 생성
            if kubectl get svc frontend-service -n jdh > /dev/null 2>&1; then
              echo "frontend-service 이미 존재 — slot selector 유지"
            else
              echo "frontend-service 없음 — slot: blue 로 초기 생성"
              kubectl apply -f - <<EOF
apiVersion: v1
kind: Service
metadata:
  name: frontend-service
  namespace: jdh
spec:
  selector:
    type: frontend
    slot: blue
  ports:
    - port: 80
      targetPort: 80
EOF
            fi
          '''
        }
      }
    }

    stage('npm Install & Build') {
      steps {
        container('node') {
          withCredentials([file(credentialsId: 'jdh-front.env', variable: 'ENV_FILE')]) {
            sh 'cp $ENV_FILE frontend/.env'
          }
          dir('frontend') {
            sh '''
              npm install
              npm run build
            '''
          }
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \\
              --context=${WORKSPACE}/frontend \\
              --dockerfile=${WORKSPACE}/frontend/Dockerfile \\
              --destination=${IMAGE_NAME}:${IMAGE_TAG} \\
              --destination=${IMAGE_NAME}:latest \\
              --single-snapshot \\
              --use-new-run \\
              --cache=true \\
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Blue/Green Deploy') {
      steps {
        container('kubectl') {
          script {
            // 현재 서비스가 가리키는 slot 확인
            def activeSlot = sh(
              script: "kubectl get svc ${SVC_NAME} -n ${NAMESPACE} -o jsonpath='{.spec.selector.slot}'",
              returnStdout: true
            ).trim()

            // active가 blue면 green에 배포, green이면 blue에 배포
            def newSlot   = (activeSlot == 'blue') ? 'green' : 'blue'
            def newDeploy = "frontend-${newSlot}-deployment"

            echo "현재 active slot: ${activeSlot} → 배포 대상: ${newSlot}"

            // inactive deployment에 새 이미지 배포 및 롤아웃 대기
            sh """
              kubectl set image deployment/${newDeploy} \\
                ${CONTAINER_NAME}=${IMAGE_NAME}:${IMAGE_TAG} \\
                -n ${NAMESPACE}

              kubectl rollout status deployment/${newDeploy} \\
                -n ${NAMESPACE} --timeout=180s
            """

            // 롤아웃 성공 → 서비스 트래픽을 새 slot으로 전환
            sh """
              kubectl patch svc ${SVC_NAME} -n ${NAMESPACE} \\
                -p '{"spec":{"selector":{"type":"frontend","slot":"${newSlot}"}}}'
            """

            echo "Blue/Green 전환 완료: ${activeSlot} → ${newSlot}"
          }
        }
      }
    }
  }

  post {
    success {
      echo "Frontend 배포 완료: ${IMAGE_NAME}:${IMAGE_TAG}"
    }
    failure {
      echo "Frontend 배포 실패 — 서비스는 기존 slot 유지"
    }
  }
}
