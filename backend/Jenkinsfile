pipeline {
  agent {
    kubernetes {
      label "gradle-kaniko-${UUID.randomUUID().toString()}"
      namespace "jdh"
      defaultContainer 'gradle'
      yaml """
apiVersion: v1
kind: Pod
metadata:
  annotations:
    sidecar.istio.io/inject: "false"
spec:
  restartPolicy: Never
  containers:
    - name: gradle
      image: eclipse-temurin:17-jdk
      command: ['cat']
      tty: true
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
    - name: kubectl
      image: bitnami/kubectl:latest
      command: ['sleep', 'infinity']
      tty: true
      securityContext:
        runAsUser: 0
  volumes:
    - name: workspace
      emptyDir: {}
    - name: docker-config
      secret:
        secretName: dockerhub-cred1
        items:
          - key: .dockerconfigjson
            path: config.json
"""
    }
  }

  environment {
    IMAGE_NAME     = 'deatytim/tmbackend'
    IMAGE_TAG      = "${env.BUILD_NUMBER}"
    NAMESPACE      = 'jdh'
    SVC_NAME       = 'backend-service'
    CONTAINER_NAME = 'backend'
  }

  stages {
    stage('Checkout') {
      steps {
        container('gradle') {
          checkout scm
        }
      }
    }

    stage('Setup K8s Resources') {
      steps {
        container('kubectl') {
          sh """
            kubectl apply -f ${WORKSPACE}/k8s/01-db-statefulset.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/02-db-service.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/03-backend-configmap.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/04-backend-deployment.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/04-backend-green-deployment.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/05-backend-service.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/08-tls-secret.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/10-backend-ingress.yaml -n ${NAMESPACE}
            kubectl apply -f ${WORKSPACE}/k8s/11-websocket-ingress.yaml -n ${NAMESPACE}
          """
        }
      }
    }

    stage('Gradle Build') {
      steps {
        container('gradle') {
          dir('backend') {
            sh '''
              chmod +x ./gradlew
              ./gradlew clean bootJar --no-daemon
            '''
          }
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \\
              --context=${WORKSPACE}/backend \\
              --dockerfile=${WORKSPACE}/backend/Dockerfile \\
              --destination=${IMAGE_NAME}:${IMAGE_TAG} \\
              --destination=${IMAGE_NAME}:latest \\
              --single-snapshot \\
              --use-new-run \\
              --cache=true \\
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Blue/Green Deploy') {
      steps {
        container('kubectl') {
          script {
            // 현재 서비스가 가리키는 slot 확인
            def activeSlot = sh(
              script: "kubectl get svc ${SVC_NAME} -n ${NAMESPACE} -o jsonpath='{.spec.selector.slot}'",
              returnStdout: true
            ).trim()

            // active가 blue면 green에 배포, green이면 blue에 배포
            def newSlot   = (activeSlot == 'blue') ? 'green' : 'blue'
            def newDeploy = "backend-${newSlot}-deployment"

            echo "현재 active slot: ${activeSlot} → 배포 대상: ${newSlot}"

            // inactive deployment에 새 이미지 배포 및 롤아웃 대기
            sh """
              kubectl set image deployment/${newDeploy} \\
                ${CONTAINER_NAME}=${IMAGE_NAME}:${IMAGE_TAG} \\
                -n ${NAMESPACE}

              kubectl rollout status deployment/${newDeploy} \\
                -n ${NAMESPACE} --timeout=180s
            """

            // 롤아웃 성공 → 서비스 트래픽을 새 slot으로 전환
            sh """
              kubectl patch svc ${SVC_NAME} -n ${NAMESPACE} \\
                -p '{"spec":{"selector":{"type":"backend","slot":"${newSlot}"}}}'
            """

            echo "Blue/Green 전환 완료: ${activeSlot} → ${newSlot}"
          }
        }
      }
    }
  }

  post {
    success {
      echo "Backend 배포 완료: ${IMAGE_NAME}:${IMAGE_TAG}"
    }
    failure {
      echo "Backend 배포 실패 — 서비스는 기존 slot 유지"
    }
  }
}
